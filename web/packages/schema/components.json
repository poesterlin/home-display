{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://esphome-designer.local/schema/components.json",
  "title": "ESPHome Designer Schema",
  "description": "Schema for ESPHome visual display editor components",
  "definitions": {
    "Position": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"],
      "additionalProperties": false
    },
    "Size": {
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "Color": {
      "type": "object",
      "properties": {
        "r": { "type": "integer", "minimum": 0, "maximum": 255 },
        "g": { "type": "integer", "minimum": 0, "maximum": 255 },
        "b": { "type": "integer", "minimum": 0, "maximum": 255 }
      },
      "required": ["r", "g", "b"],
      "additionalProperties": false
    },
    "EntityBinding": {
      "type": "object",
      "properties": {
        "entityId": { "type": "string", "pattern": "^[a-z_]+\\.[a-z_0-9]+$" },
        "attribute": { "type": ["string", "null"] }
      },
      "required": ["entityId"],
      "additionalProperties": false
    },
    "ServiceAction": {
      "type": "object",
      "properties": {
        "type": { "const": "SERVICE_CALL" },
        "service": { "type": "string", "pattern": "^[a-z_]+\\.[a-z_0-9]+$" },
        "target": { "$ref": "#/definitions/EntityBinding" },
        "data": { "type": "object" }
      },
      "required": ["type", "service"],
      "additionalProperties": false
    },
    "NavigationAction": {
      "type": "object",
      "properties": {
        "type": { "enum": ["OPEN_DETAIL", "GO_BACK", "NEXT_PAGE", "PREV_PAGE"] },
        "targetId": {
          "type": "string",
          "pattern": "^[A-Z_]+$",
          "description": "Detail view ID (without VIEW_DETAIL_ prefix). Required for OPEN_DETAIL."
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "ActionBinding": {
      "oneOf": [
        { "$ref": "#/definitions/ServiceAction" },
        { "$ref": "#/definitions/NavigationAction" }
      ]
    },
    "OnTapAction": {
      "oneOf": [
        { "$ref": "#/definitions/ServiceAction" },
        { "$ref": "#/definitions/NavigationAction" }
      ]
    },
    "BaseComponent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "position": { "$ref": "#/definitions/Position" },
        "size": { "$ref": "#/definitions/Size" },
        "visible": { "type": "boolean", "default": true },
        "visibleWhen": { "$ref": "#/definitions/EntityBinding" },
        "loadingBinding": { "$ref": "#/definitions/EntityBinding" },
        "onTap": { "$ref": "#/definitions/OnTapAction" },
        "onHold": { "$ref": "#/definitions/OnTapAction" },
        "onDragStart": { "$ref": "#/definitions/OnTapAction" },
        "onDragEnd": { "$ref": "#/definitions/OnTapAction" },
        "variant": { "enum": ["default", "retro", "minimal"], "default": "retro" }
      },
      "required": ["id", "type", "position"]
    },
    "TextComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" },
            "textBinding": { "$ref": "#/definitions/EntityBinding" },
            "fontSize": { "enum": ["small", "medium", "large"], "default": "medium" },
            "color": { "$ref": "#/definitions/Color" },
            "align": { "enum": ["left", "center", "right"], "default": "left" }
          },
          "required": ["type"]
        }
      ]
    },
    "ButtonComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "button" },
            "label": { "type": "string" },
            "icon": { "type": "string" },
            "backgroundColor": { "$ref": "#/definitions/Color" },
            "pressAction": { "$ref": "#/definitions/ActionBinding" },
            "holdAction": { "$ref": "#/definitions/ActionBinding" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "SliderComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "slider" },
            "min": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 100 },
            "step": { "type": "number", "default": 1 },
            "valueBinding": { "$ref": "#/definitions/EntityBinding" },
            "onChange": { "$ref": "#/definitions/ActionBinding" },
            "orientation": { "enum": ["horizontal", "vertical"], "default": "horizontal" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "GaugeComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "gauge" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "valueBinding": { "$ref": "#/definitions/EntityBinding" },
            "unit": { "type": "string" },
            "segments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "number" },
                  "to": { "type": "number" },
                  "color": { "$ref": "#/definitions/Color" }
                },
                "required": ["from", "to", "color"],
                "additionalProperties": false
              }
            }
          },
          "required": ["type", "size", "min", "max"]
        }
      ]
    },
    "IconComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "icon" },
            "icon": { "type": "string" },
            "color": { "$ref": "#/definitions/Color" },
            "scale": { "type": "number", "default": 1 }
          },
          "required": ["type", "size", "icon"]
        }
      ]
    },
    "ProceduralIconComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "procedural_icon" },
            "iconType": { "enum": ["bulb", "window", "vacuum", "climate"] },
            "stateBinding": { "$ref": "#/definitions/EntityBinding" },
            "color": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "size", "iconType"]
        }
      ]
    },
    "ContainerComponent": {
      "allOf": [
        { "$ref": "#/definitions/BaseComponent" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "container" },
            "label": { "type": "string" },
            "backgroundColor": { "$ref": "#/definitions/Color" }
          },
          "required": ["type", "size"]
        }
      ]
    },
    "Component": {
      "oneOf": [
        { "$ref": "#/definitions/TextComponent" },
        { "$ref": "#/definitions/ButtonComponent" },
        { "$ref": "#/definitions/SliderComponent" },
        { "$ref": "#/definitions/GaugeComponent" },
        { "$ref": "#/definitions/IconComponent" },
        { "$ref": "#/definitions/ProceduralIconComponent" },
        { "$ref": "#/definitions/ContainerComponent" }
      ]
    },
    "Page": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "backgroundColor": { "$ref": "#/definitions/Color" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" }
        }
      },
      "required": ["id", "name", "components"],
      "additionalProperties": false
    },
    "DetailView": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z_]+$",
          "description": "Short view name in UPPER_SNAKE_CASE (e.g., TEMPS, VACUUM). Generator prepends VIEW_DETAIL_ prefix for enum."
        },
        "title": { "type": "string" },
        "height": {
          "type": "number",
          "description": "Total virtual height in pixels; maxScrollY = height - headerHeight"
        },
        "headerHeight": {
          "type": "number",
          "default": 45,
          "description": "Height of the detail view header (default: 45px)"
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/definitions/Component" }
        }
      },
      "required": ["id", "title", "height", "components"],
      "additionalProperties": false
    },
    "StateField": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "description": "Variable name in gState (e.g., outsideTemp)"
        },
        "cppType": {
          "type": "string",
          "enum": ["float", "int", "bool", "std::string"],
          "description": "C++ type"
        },
        "haEntity": {
          "type": "string",
          "pattern": "^[a-z_]+\\.[a-z_0-9]+$",
          "description": "Home Assistant entity (sensor.outside_temp)"
        },
        "defaultValue": {
          "type": ["string", "number", "boolean"],
          "description": "Initial value (e.g., 0, false, '')"
        }
      },
      "required": ["name", "cppType", "haEntity"],
      "additionalProperties": false
    },
    "StateConfig": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/StateField" },
          "description": "Sensor fields to include in DisplayState"
        }
      },
      "additionalProperties": false
    },
    "Theme": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "colors": {
          "type": "object",
          "properties": {
            "background": { "$ref": "#/definitions/Color" },
            "backgroundSecondary": { "$ref": "#/definitions/Color" },
            "foreground": { "$ref": "#/definitions/Color" },
            "foregroundMuted": { "$ref": "#/definitions/Color" },
            "accent": { "$ref": "#/definitions/Color" },
            "accentSecondary": { "$ref": "#/definitions/Color" },
            "success": { "$ref": "#/definitions/Color" },
            "warning": { "$ref": "#/definitions/Color" },
            "error": { "$ref": "#/definitions/Color" }
          },
          "required": ["background", "foreground", "accent"]
        },
        "style": {
          "type": "object",
          "properties": {
            "buttonShadow": { "type": "boolean" },
            "buttonCornerAccents": { "type": "boolean" },
            "containerCorners": { "type": "boolean" },
            "headerBorders": { "type": "boolean" }
          }
        },
        "values": {
          "type": "object",
          "properties": {
            "shadowOffset": { "type": "number" },
            "cornerSize": { "type": "number" },
            "borderRadius": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "colors"]
    },
    "FontDefinition": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "file": { "type": "string" },
        "size": { "type": "integer" }
      },
      "required": ["id", "file", "size"],
      "additionalProperties": false
    },
    "DisplayConfig": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "platform": { "enum": ["ili9xxx", "st7789", "ssd1306", "waveshare_epaper"] }
      },
      "required": ["width", "height", "platform"],
      "additionalProperties": false
    },
    "Project": {
      "type": "object",
      "properties": {
        "version": { 
          "type": "string", 
          "description": "Schema version. ALWAYS increment this if there are breaking changes to the JSON structure.",
          "default": "1.0.0"
        },
        "name": { "type": "string" },
        "theme": { "$ref": "#/definitions/Theme" },
        "display": { "$ref": "#/definitions/DisplayConfig" },
        "state": { "$ref": "#/definitions/StateConfig" },
        "dashboardPages": {
          "type": "array",
          "items": { "$ref": "#/definitions/Page" }
        },
        "detailViews": {
          "type": "array",
          "items": { "$ref": "#/definitions/DetailView" }
        },
        "fonts": {
          "type": "array",
          "items": { "$ref": "#/definitions/FontDefinition" }
        }
      },
      "required": ["name", "display", "dashboardPages", "detailViews"],
      "additionalProperties": false
    }
  }
}
